<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">
  <category id="ph_sensor" name="Cảm biến pH" colour="#00a86b" icon="flask">
    <block type="uno_ph_create"></block>
    <block type="uno_ph_read"></block>
    <block type="uno_ph_read_voltage"></block>
    <block type="uno_ph_add_point">
      <value name="PH">
        <shadow type="math_number">
          <field name="NUM">6.86</field>
        </shadow>
      </value>
    </block>
    <block type="uno_ph_num_points"></block>
    <block type="uno_ph_reset"></block>
  </category>
</xml>
